# Supabase (auth + Postgres)
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Necessário para o worker de sincronização (backend apenas; não expor no client)
SUPABASE_SERVICE_ROLE_KEY=

# Mercado Livre OAuth (client_secret NUNCA no client)
MERCADOLIVRE_CLIENT_ID=
MERCADOLIVRE_CLIENT_SECRET=
# Deve ser EXATAMENTE a URL de callback do SEU app (e estar cadastrada no app ML)
# Desenvolvimento: use a URL onde o Next roda (porta 3001)
MERCADOLIVRE_REDIRECT_URI=http://localhost:3001/api/mercadolivre/callback

# App (para callbacks e links)
NEXT_PUBLIC_APP_URL=http://localhost:3001

# Logs da sincronização de anúncios no console do servidor (PM2 / Docker)
# SYNC_LOG_VERBOSE=1
# SYNC_LOG_HEARTBEAT_MS=15000

# Sincronização ML: paralelismo (1 = um anúncio por vez). Só aumente se o ML não limitar.
# ML_SYNC_CONCURRENCY=1
# Fila única de HTTP ao Mercado Livre no servidor (recomendado; reduz 429). 0 = paralelo (mais rápido, mais 429).
# ML_HTTP_SERIAL=1
